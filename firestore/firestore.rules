rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı fonksiyonlar ──────────────────────────────────────────────
    function isAuth()       { return request.auth != null; }
    function uid()          { return request.auth.uid; }
    function userRole()     { return get(/databases/$(database)/documents/users/$(uid())).data.role; }
    function isSuperAdmin() { return isAuth() && userRole() == "superadmin"; }
    function isAdmin()      { return isAuth() && userRole() in ["superadmin","admin"]; }
    function isTeacher()    { return isAuth() && userRole() in ["superadmin","admin","teacher"]; }
    function isOwner(ownerId) { return isAuth() && uid() == ownerId; }

    // ─── Kullanıcılar ───────────────────────────────────────────────────────
    // Okuma: kendi profilini veya admin
    // Yazma: sadece backend (Admin SDK) — doğrudan client yazamaz
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false; // Sadece backend Functions yazar
    }

    // ─── Araçlar ────────────────────────────────────────────────────────────
    match /tools/{doc} {
      allow read:  if true;  // Herkese açık
      allow write: if false; // Sadece backend
    }

    // ─── Sorular ────────────────────────────────────────────────────────────
    match /questions/{doc} {
      allow read:  if isAuth(); // Üye gerekli
      allow write: if false;    // Sadece backend
      match /answers/{ans} {
        allow read:  if isAuth();
        allow write: if false;
      }
    }

    // ─── Sınıflar ───────────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read:  if isAuth() && (resource.data.teacherUid == uid() || isAdmin());
      allow write: if false; // Sadece backend
      match /students/{studentId} {
        allow read:  if isAuth() && (get(/databases/$(database)/documents/classes/$(classId)).data.teacherUid == uid() || isAdmin());
        allow write: if false;
      }
    }

    // ─── Arızalar ───────────────────────────────────────────────────────────
    match /arizalar/{doc} {
      allow read:  if isAuth();
      allow write: if false; // Sadece backend
    }

    // ─── Duyurular ──────────────────────────────────────────────────────────
    match /announcements/{doc} {
      allow read:  if resource.data.active == true;
      allow write: if false;
    }

    // ─── Medya ──────────────────────────────────────────────────────────────
    match /media/{doc} {
      allow read:  if isAuth();
      allow write: if false;
    }

    // ─── Raporlar ───────────────────────────────────────────────────────────
    match /reports/{doc} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ─── Audit logları — sadece backend okur/yazar ───────────────────────────
    match /audit_logs/{doc} {
      allow read:  if isSuperAdmin();
      allow write: if false;
    }

    // ─── Ayarlar ────────────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ─── Ziyaretçi defteri ──────────────────────────────────────────────────
    match /guestbook/{doc} {
      allow read:  if resource.data.status == "approved";
      allow create: if true; // Herkes yazabilir, admin onaylar
      allow update, delete: if isAdmin();
    }
  }
}
