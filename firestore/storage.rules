rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Medya dosyaları — auth gerekli, max 50MB
    match /media/{category}/{file} {
      allow read:  if request.auth != null;
      allow write: if false; // Sadece backend Functions yazar
    }
    // Tool logoları — herkese açık okuma
    match /tool-logos/{file} {
      allow read:  if true;
      allow write: if false;
    }
    // Profil fotoğrafları
    match /profiles/{uid}/{file} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
