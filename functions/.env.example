# Firebase Admin SDK — bu dosyayı GİTHUB'A YÜKLEME (.gitignore'a ekli)
# Firebase Console → Proje Ayarları → Hizmet Hesapları → Yeni özel anahtar oluştur

FIREBASE_PROJECT_ID=fclwebaraclari
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@fclwebaraclari.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# JWT Secret — rastgele güçlü bir string
JWT_SECRET=buraya-en-az-64-karakter-rastgele-string-girin

# Super Admin e-postası (sistem kurulumunda bir kez set edilir)
SUPER_ADMIN_EMAIL=ahmetcecen@yenilikcisinif.meb.gov.tr

# Ortam
NODE_ENV=production
